---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Portafolio — Fullstack Developer",
  description = "Ingeniero Informático Multimedia y Desarrollador Full Stack",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Fuentes (también pueden moverse a un plugin de Astro) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Josefin+Sans:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="relative overflow-x-hidden">
    <slot />
  </body>
</html>

<!-- Estilos globales (no scoped) -->
<style is:global>
  @import "../styles/global.css";
</style>
