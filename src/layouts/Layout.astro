---
interface Props {
  title: string;
}

import Footer from "../components/common/footer.astro";
import Header from "../components/header.astro";
import SquareLines from "../components/square-lines.astro";
const { title } = Astro.props;
import "../assets/css/main.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Fragment set:html={import.meta.env.HEADER_INJECT} />
  </head>
  <body
    class="min-h-screen flex flex-col antialiased bg-gradient-to-tr from-gray-950 from-90% via-90% to-100%"
  >
    <SquareLines />
    <Header />
    <div class="flex-grow">
      <slot />
    </div>
    <Footer />
    <script src="../assets/js/main.js"></script>
    <Fragment set:html={import.meta.env.FOOTER_INJECT} />
  </body>
</html>
