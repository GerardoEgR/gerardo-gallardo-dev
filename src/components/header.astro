---
interface Props {
  title?: string[]; // Líneas del h1
  subtitle?: string;
  linkedinUrl?: string;
  githubUrl?: string;
}

const {
  title = ["Gerardo", "Gallardo", "Rodríguez"],
  subtitle = "Ingeniero Informático Multimedia y Desarrollador Full Stack con experiencia creando soluciones digitales, preparadas para soportar ecosistemas exigentes.",
  linkedinUrl = "https://www.linkedin.com/in/gerardogallardo-dev",
  githubUrl = "https://github.com/GerardoEgR",
} = Astro.props;
---

<section id="hero" class="hero-bg min-h-screen flex items-center relative pt-24">
  <!-- Línea decorativa vertical -->
  <div
    class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-gold-600/30 to-transparent hidden lg:block ml-16"
  >
  </div>
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-2/3 h-[1px] bg-gradient-to-r from-transparent via-yellow-600/30 to-transparent"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Contenido izquierdo -->
      <div class="space-y-8">
        <div class="reveal">
          <span class="section-label">Fullstack Developer</span>
          <div class="gold-line mt-2 mb-5"></div>
        </div>

        <div class="reveal reveal-delay-1 pb-10">
          <h1 class="font-display text-6xl md:text-7xl lg:text-8xl leading-none font-light">
            <span class="text-ivory-100 italic">{title[0]}</span><br />
            <span class="gold-text italic">{title[1]}</span><br />
            <span class="text-ivory-100 italic">{title[2]}</span><br />
          </h1>
        </div>

        <div class="reveal reveal-delay-2 pb-10">
          <p class="text-ivory-300/70 font-body font-light text-base leading-relaxed max-w-md">
            {subtitle}
          </p>
        </div>

        <!-- Redes sociales -->
        <div class="reveal reveal-delay-3 flex items-center gap-6">
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            class="flex items-center gap-3 text-ivory-300 hover:text-gold-400 transition-all duration-300 group"
          >
            <svg
              class="w-5 h-5 transition-transform group-hover:scale-110"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            <span class="text-xs tracking-widest uppercase font-semibold">LinkedIn</span>
          </a>

          <div class="w-px h-4 bg-gold-700/40"></div>

          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            class="flex items-center gap-3 text-ivory-300 hover:text-gold-400 transition-all duration-300 group"
          >
            <svg
              class="w-5 h-5 transition-transform group-hover:scale-110"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            <span class="text-xs tracking-widest uppercase font-semibold">GitHub</span>
          </a>
        </div>

        <!-- CTAs -->
        <div class="reveal reveal-delay-4 flex items-center gap-4 pt-2">
          <a href="#projects" class="btn-gold px-8 py-3 text-xs rounded-sm">Proyectos</a>
          <a href="#contact" class="btn-ghost px-8 py-3 text-xs rounded-sm">Contacto</a>
        </div>
      </div>

      <!-- Decoración derecha: anillos animados -->
      <div class="hidden lg:flex justify-center items-center reveal reveal-delay-2">
        <div class="relative w-80 h-80">
          <!-- Anillo exterior -->
          <div
            class="absolute inset-0 rounded-full border border-gold-600/15 animate-spin"
            style="animation-duration:25s;"
          >
          </div>
          <!-- Anillo medio -->
          <div
            class="absolute inset-6 rounded-full border border-gold-500/20 animate-spin"
            style="animation-duration:18s; animation-direction:reverse;"
          >
          </div>
          <!-- Glow interior -->
          <div
            class="absolute inset-12 rounded-full border border-gold-500/25"
            style="background: radial-gradient(ellipse at center, rgba(201,168,76,0.08) 0%, transparent 70%);"
          >
          </div>
          <!-- Centro -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="font-display text-7xl font-semibold gold-text leading-none">
                &lt;/&gt;
              </div>
              <div class="mt-3 text-xs tracking-[0.4em] uppercase text-ivory-300/50 font-body">
                Full Stack
              </div>
            </div>
          </div>
          <!-- Puntos decorativos -->
          <div
            class="absolute top-3 left-1/2 w-2 h-2 rounded-full bg-gold-500/60 -translate-x-1/2 animate-pulse"
          >
          </div>
          <div
            class="absolute bottom-3 left-1/2 w-1.5 h-1.5 rounded-full bg-gold-600/40 -translate-x-1/2 animate-pulse"
            style="animation-delay:1s;"
          >
          </div>
          <div
            class="absolute left-3 top-1/2 w-1.5 h-1.5 rounded-full bg-gold-600/40 -translate-y-1/2 animate-pulse"
            style="animation-delay:0.5s;"
          >
          </div>
          <div
            class="absolute right-3 top-1/2 w-2 h-2 rounded-full bg-gold-500/60 -translate-y-1/2 animate-pulse"
            style="animation-delay:1.5s;"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-20 flex justify-center">
      <div class="flex flex-col items-center gap-2 animate-bounce opacity-50">
        <span class="text-xs tracking-widest uppercase text-ivory-300/50 font-body">Scroll</span>
        <svg
          class="w-4 h-4 text-gold-600"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 80% 60% at 50% 110%, rgba(201, 168, 76, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 20%, rgba(201, 168, 76, 0.04) 0%, transparent 60%),
      #0d0d0d;
  }
</style>

<!-- Trigger reveal para el hero al cargar (sin esperar scroll) -->
<script>
  window.addEventListener("load", () => {
    document.querySelectorAll("#hero .reveal").forEach((el) => {
      setTimeout(() => el.classList.add("visible"), 200);
    });
  });
</script>
