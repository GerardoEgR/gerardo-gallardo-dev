const extraBadges = ["PostgreSQL", "MySQL", "Docker", "Git", "REST APIs"];
---

<section id="stack" class="py-28 relative">
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-2/3 h-[1px] bg-gradient-to-r from-transparent via-yellow-600/30 to-transparent"
  >
  </div>
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Encabezado -->
    <div class="mb-20 reveal">
      <span class="section-label">Habilidades</span>
      <div class="gold-line mt-4 mb-5"></div>
      <h2 class="font-display text-5xl md:text-6xl font-light text-ivory-100">
        Stack <span class="gold-text font-semibold italic">Tecnológico</span>
      </h2>
      <p class="mt-4 text-ivory-300/60 font-body font-light text-base max-w-xl leading-relaxed">
        Herramientas y tecnologías que encontrarás trabajando conmigo para crear soluciones
        digitales.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- ── Frontend ── -->
      <div class="reveal reveal-delay-2">
        <div class="mb-6 flex items-center gap-4">
          <div
            class="w-8 h-8 flex items-center justify-center border border-gold-600/40 rounded-sm"
          >
            <svg
              class="w-4 h-4 text-gold-500"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-body font-semibold text-sm tracking-widest uppercase text-gold-400">
              Frontend
            </h3>
            <p class="text-ivory-300/40 text-xs tracking-wider">Client-side & UI/UX</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {
            frontendStack.map((item) => (
              <div class="stack-card p-4 rounded-sm flex items-center gap-8">
                <div class="w-7 h-7 text-gold-500 flex-shrink-0" set:html={item.icon} />
                <div>
                  <p class="font-body font-semibold text-sm text-ivory-100">{item.name}</p>
                  <p class="text-xs text-ivory-300/40">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- ── Backend ── -->
      <div class="reveal reveal-delay-1">
        <div class="mb-6 flex items-center gap-4">
          <div
            class="w-8 h-8 flex items-center justify-center border border-gold-600/40 rounded-sm"
          >
            <svg
              class="w-4 h-4 text-gold-500"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="font-body font-semibold text-sm tracking-widest uppercase text-gold-400">
              Backend
            </h3>
            <p class="text-ivory-300/40 text-xs tracking-wider">Server-side & APIs</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {
            backendStack.map((item) => (
              <div
                class:list={[
                  "stack-card p-4 rounded-sm flex items-center gap-8",
                  item.colSpan && "col-span-2",
                ]}
              >
                <div class="w-7 h-7 text-gold-500 flex-shrink-0" set:html={item.icon} />
                <div>
                  <p class="font-body font-semibold text-sm text-ivory-100">{item.name}</p>
                  <p class="text-xs text-ivory-300/40">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
        <!-- Badges adicionales -->
        <div class="mt-4 p-4 border border-gold-700/15 rounded-sm bg-noir-800/40">
          <p class="text-xs tracking-widest uppercase text-ivory-300/40 mb-3">
            También trabajo con
          </p>
          <div class="flex flex-wrap gap-2">
            {extraBadges.map((badge) => <span class="tech-badge">{badge}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
