---
interface Props {
  linkedinUrl?: string;
  linkedinLabel?: string;
  githubUrl?: string;
  githubLabel?: string;
}

const {
  linkedinUrl = "https://www.linkedin.com/in/gerardogallardo-dev/",
  linkedinLabel = "linkedin.com/in/gerardogallardo-dev",
  githubUrl = "https://github.com/GerardoEgR",
  githubLabel = "github.com/GerardoEgR",
} = Astro.props;

/* ícono de flecha externa compartido */
const externalArrowPath =
  "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14";
---

<section id="contact" class="py-28 relative">
  <!-- Gradiente decorativo -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-gold-500/[0.02] to-transparent pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <!-- ── Columna izquierda: presentación + stats ── -->
      <div class="reveal">
        <span class="section-label">Contacto</span>
        <div class="gold-line mt-2 mb-5"></div>
        <h2 class="font-display text-5xl md:text-6xl font-light text-ivory-100 leading-tight">
          Construyamos<br />
          <span class="gold-text font-semibold italic">algo juntos.</span>
        </h2>
        <p class="mt-6 text-ivory-300/60 font-body font-light text-base leading-relaxed max-w-md">
          Cada gran proyecto comienza con una conversación.
        </p>
      </div>

      <!-- ── Columna derecha: links + formulario ── -->
      <div class="reveal reveal-delay-1 space-y-6">
        <!-- Links sociales -->
        <div class="space-y-3">
          <!-- LinkedIn -->
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener"
            class="contact-link flex items-center gap-5 p-5 rounded-sm group"
          >
            <div
              class="w-10 h-10 flex items-center justify-center border border-gold-700/30 rounded-sm bg-gold-500/5 group-hover:border-gold-500/50 transition-colors"
            >
              <svg class="w-5 h-5 text-gold-500" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="font-body font-semibold text-sm text-ivory-100">LinkedIn</p>
              <p class="text-xs text-ivory-300/50 mt-0.5">{linkedinLabel}</p>
            </div>
            <svg
              class="w-4 h-4 text-ivory-300/30 group-hover:text-gold-500 transition-colors"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={externalArrowPath}></path>
            </svg>
          </a>

          <!-- GitHub -->
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="contact-link flex items-center gap-5 p-5 rounded-sm group"
          >
            <div
              class="w-10 h-10 flex items-center justify-center border border-gold-700/30 rounded-sm bg-gold-500/5 group-hover:border-gold-500/50 transition-colors"
            >
              <svg class="w-5 h-5 text-gold-500" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="font-body font-semibold text-sm text-ivory-100">GitHub</p>
              <p class="text-xs text-ivory-300/50 mt-0.5">{githubLabel}</p>
            </div>
            <svg
              class="w-4 h-4 text-ivory-300/30 group-hover:text-gold-500 transition-colors"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={externalArrowPath}></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
