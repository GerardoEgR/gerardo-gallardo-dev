---
import Layout from "../layouts/Layout.astro";
import Header from "../components/header.astro";
import Navbar from "../components/common/navbar.astro";
import Stack from "../components/stack.astro";
import Projects from "../components/projects.astro";
import Contact from "../components/contact.astro";
import Footer from "../components/common/footer.astro";
import ScrollReveal from "../components/scroll-reveal.astro";

const contactData = {
  linkedinUrl: "https://linkedin.com/in/tu-perfil",
  linkedinLabel: "linkedin.com/in/tu-perfil",
  githubUrl: "https://github.com/tu-usuario",
  githubLabel: "github.com/tu-usuario",
};
---

<Layout
  title="Portafolio — Fullstack Developer"
  description="Ingeniero Informático Multimedia y Desarrollador Full Stack. Angular, NestJS, Spring Boot, PostgreSQL."
>
  <Navbar />
  <main>
    <Header />
    <Stack />
    <Projects />
    <Contact />
  </main>
  <Footer linkedinUrl={contactData.linkedinUrl} githubUrl={contactData.githubUrl} />
  <ScrollReveal />
</Layout>
